// The generator source. Run with tsx (npm run generate); never emitted by tsc.
{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["input"]
}
